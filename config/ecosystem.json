      "healthcheck": "/health",
      "buildCommand": "pnpm run build",
      "startCommand": "pnpm run start",
      "internalUrl": "http://neobot.railway.internal"
    }
  },
  {
    "id": "neo-mcp-server",
    "org": "NEO Protocol",
    "name": "NEO MCP Server",
    "description": "Runtime MCP híbrido do NEO Protocol. Storacha cobre persistencia e recuperacao de artefatos; Railway sustenta o serviço publico em mcp.neoprotocol.space.",
    "localPath": "../neo-mcp-server",
    "repository": "https://github.com/NEO-PROTOCOL/neo-mcp-server.git",
    "role": "MCP Storage Runtime / Railway Service",
    "mcpRuntime": {
      "provider": "Storacha",
      "tools": ["upload", "retrieve", "identity"],
      "transports": ["stdio", "sse", "rest"],
      "requiredEnv": ["MCP_TRANSPORT_MODE", "MCP_SERVER_PORT", "MAX_FILE_SIZE"],
      "privateRequiredEnv": ["PRIVATE_KEY", "DELEGATION"]
    },
    "hosting": {
      "platform": "Railway / Storacha",
      "productionUrl": "https://mcp.neoprotocol.space",
      "railwayUrl": "https://neo-mcp-server.up.railway.app",
      "internalUrl": "http://neo-mcp-server.railway.internal",
      "targetCustomDomain": "mcp.neoprotocol.space",
      "adminEmail": "neo@neoprotocol.space",
      "note": "Storacha segue como camada de persistencia. Railway expõe o runtime publico e o healthcheck em /health.",
      "healthcheck": "/health",
      "buildCommand": "pnpm build",
      "startCommand": "pnpm start"
    }
  },
