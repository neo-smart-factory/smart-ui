# ============================================
# NΞØ SMART FACTORY — Interface Configuration
# Version: 0.5.6
# ============================================
# 
# IMPORTANTE: Copie este arquivo para .env e preencha com seus valores reais
# cp .env.example .env
#
# NUNCA commite o arquivo .env com valores reais no Git!
#

# ============================================
# 1. Database (Neon.tech - Serverless Postgres)
# ============================================
# Recomendado para deploy na Vercel (Hobby Tier)
# Obtenha sua URL em: https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-cool-name-123456.us-east-2.aws.neon.tech/neodb?sslmode=require"
DIRECT_URL="" # Usado para migrações se necessário (opcional)

# ============================================
# 2. Blockchain / Web3
# ============================================
# Chain ID padrão (Base Mainnet: 8453, Base Sepolia: 84532)
VITE_CHAIN_ID=8453
# RPC URL para conexão com blockchain
VITE_RPC_URL="https://mainnet.base.org"

# RPC Providers (escolha um ou ambos)
# Alchemy: https://www.alchemy.com/
VITE_ALCHEMY_ID=""
# dRPC: https://drpc.org/
VITE_DRPC_API_KEY=""

# ============================================
# 3. Authentication (Dynamic.xyz)
# ============================================
# Dynamic.xyz - Auth unificado (Wallet + Social)
# Obtenha em: https://app.dynamic.xyz/
VITE_DYNAMIC_ENVIRONMENT_ID=""

# ============================================
# 4. AI Services (Tavily)
# ============================================
# Tavily - AI Search & Research API
# Obtenha API key em: https://tavily.com/
TAVILY_API_KEY=""

# ============================================
# 5. Integration Secrets
# ============================================
# Nexus Vault - Autenticação de Webhooks
# Usado para validar assinaturas do NΞØ Nexus no endpoint /api/webhooks/factory
# IMPORTANTE: Gere um valor aleatório forte (ex: openssl rand -hex 32)
NEXUS_SECRET=""

# Notion Webhook Secret
# Usado para validar webhooks do Notion via /api/webhooks/notion
NOTION_WEBHOOK_SECRET=""

# Analytics Admin Token - protege o endpoint analytics-fetch
# IMPORTANTE: Gere um valor aleatório forte (ex: openssl rand -hex 32)
ANALYTICS_ADMIN_TOKEN=""

# ============================================
# 6. Error Tracking (Sentry)
# ============================================
# Opcional: Monitoramento de erros em produção
# Obtenha DSN em: https://sentry.io/
VITE_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"

# ============================================
# 7. GitHub Integration (Cross-Repo)
# ============================================
# Personal Access Token para integração com neo-smart-factory
# Gere em: GitHub → Settings → Developer settings → Personal access tokens
# Permissões necessárias: repo (Full control of private repositories)
# IMPORTANTE: Configure como secret no GitHub Actions, não aqui!
# NEO_ECOSYSTEM_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxx"

# ============================================
# 8. Feature Flags & Overrides
# ============================================
# Simulation mode por padrão (true = simula, false = real Web3)
VITE_ENABLE_WEB3=false
# Analytics (opcional)
VITE_ENABLE_ANALYTICS=false
# Debug mode (desenvolvimento)
VITE_DEBUG_MODE=true

# Overrides de Feature Flag (Exemplos)
# VITE_FEATURE_PHASE2_WEB3=true
# VITE_FEATURE_PHASE3_AIDOCTOR=false

# ============================================
# 9. Ecosystem Synchronization (Local Dev Only)
# ============================================
# Em produção, estas serão substituídas por APIs via Neon.tech
# Ajuste os caminhos conforme sua estrutura local
INTERNAL_OPS_PATH="../neo-smart-factory/internal-ops/state.json"
CORE_CONTRACTS_PATH="../neo-smart-factory/smart-core/contracts"

# ============================================
# 10. Global Config
# ============================================
VITE_APP_VERSION="0.5.6"
VITE_APP_CODENAME="NΞØ PROTOCOL"
NODE_ENV="production"

